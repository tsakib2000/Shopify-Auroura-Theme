<!-- blog-grid-8.liquid -->
<div class="blog__item blog__item--8 {% if template contains 'index' %} pb-0 {% endif %}" data-aos="{{ animation }}">
    {%- if article.image -%}
    <div class="content-block__image mb-4 position-relative">
      <a href="{{ article.url }}">
        <noscript>
          {{ article | image_url: width: 1024, height: 1024 | image_tag: article.title | escape }}
        </noscript>
        <div class="article__photo-container">
          <div class="article__photo-wrapper {{ image_size }}" style="padding-top:{{ 1 | divided_by: article.image.aspect_ratio | times: 100 }}%;">
            {%- assign img_url = article.image | image_url: width: 1 | replace: 'width=1', 'width={width}' -%}
            <img class="lazyload scale-in"
                 src="{{ article | image_url: width: 1, height: 1 }}"
                 data-src="{{ img_url }}"
                 data-widths="[360, 540, 720, 900, 1080, 1296, 1512, 1728, 2048]"
                 data-aspectratio="{{ article.image.aspect_ratio }}"
                 data-sizes="auto"
                 alt="{{ article.title | escape }}"
                 loading="lazy"
                 width="{{ article.image.width }}"
                height="{{ article.image.height }}" >
          </div>
        </div>
      </a>
      {%- if enable_tag -%}
      {%- if article.tags.size > 0 -%}
        <div class="blog_tag position-absolute bottom-0 start-0 text-uppercase">
          {%- for tag in article.tags -%}
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="link-body-color">{{ tag }}</a>{% unless forloop.last %}, {% endunless %}
          {%- endfor -%}
        </div>
      {%- endif -%}
    {%- endif -%}
    </div>
    {%- endif -%}
    <div class="blog__content">
    
    <h4 class="blog__title-link {% if settings.enable_short %}  mb-3 {% else %} mb-4 {% endif %}"><a href="{{ article.url }}">{{ article.title }}</a></h4>
    {%- if enable_short -%}
    <div style="width:70px;"><hr ></div>
    <div class="rte rte--indented-images mb-4">
      {%- if article.excerpt.size > 0 -%}
      {{ article.excerpt }}
      {%- else -%}
        {%- if template contains 'index' -%}
        <p class="txt-body-80">{{ article.content | strip_html | truncatewords: 15 }}</p>
        {%- else -%}
        <p class="txt-body-80">{{ article.content | strip_html | truncatewords: 20 }}</p>
        {%- endif -%}
      {%- endif -%}
    </div>
    {%- endif -%}
    <div class="d-flex align-items-center gap-2 ">
        <p class="text-uppercase small m-0">
            Post by {{article.author}}
        </p>
        {%- if enable_date -%}
        <span>/</span>
        <p class="blog__meta">
          <time datetime="{{ article.published_at }}">
            <span class="meta-b">{{ article.published_at | date: "%b" }}</span>
            <span class="meta-d">{{ article.published_at | date: "%d" }}</span>
            <span class="meta-y">{{ article.published_at | date: "%Y" }}</span>
          </time>
        </p>
      {%- endif -%}
    </div>
     
    {%- if enable_btn_blog -%}
    <a  class="btn {% if enable_btn_line %} btn-underline {% else %} btn-theme btn-sm {% endif %} gradient-theme {% if template contains 'index' %} mb-0 {% else %}mb-4{% endif %}" href="{{ article.url }}" title="{{ article.title }}">{{ 'blogs.article.read_more' | t }}</a>  
    {%- endif -%}
  </div>
  </div>